# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/milesup?schema=public

# Auth
JWT_ACCESS_SECRET=change-this-to-a-32-character-minimum-secret
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_SALT_ROUNDS=10

# Verification and checkout
VERIFICATION_CODE_TTL_MINUTES=10
CHECKOUT_SESSION_TTL_MINUTES=30
EXPOSE_DEV_CODES=true

# Email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=no-reply@milesup.local
MAIL_FROM_NAME=MilesUp
MAIL_REPLY_TO=support@milesup.local

# Dev notification adapter
DEV_NOTIFICATION_EMAIL=dev-inbox@milesup.local

# Optional: integration tests on Windows or against a dedicated local DB
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/milesup_test?schema=public
